# =============================================================================
#  Clarity — MariaDB Server Configuration
#  /etc/mysql/conf.d/clarity.cnf
#  Loaded after /etc/mysql/my.cnf by the base image
#  Tuned for a k3s pod with 1–4 GB RAM allocated
# =============================================================================

[mysqld]

# ---------------------------------------------------------------------------
# Character set — must match the schema (utf8mb4 / utf8mb4_unicode_ci)
# ---------------------------------------------------------------------------
character_set_server            = utf8mb4
collation_server                = utf8mb4_unicode_ci

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------
# Bind to all interfaces — access controlled via k8s NetworkPolicy
bind_address                    = 0.0.0.0
port                            = 3306

# Resolve client IPs as hostnames? No — pods have no DNS reverse resolution.
# This avoids startup delays in k8s environments.
skip_name_resolve               = ON

# ---------------------------------------------------------------------------
# Connection management
# ---------------------------------------------------------------------------
max_connections                 = 200
max_connect_errors              = 10000
connect_timeout                 = 10
wait_timeout                    = 600
interactive_timeout             = 600
net_read_timeout                = 60
net_write_timeout               = 60

# ---------------------------------------------------------------------------
# InnoDB — primary storage engine for all Clarity tables
# ---------------------------------------------------------------------------
# Buffer pool: cache for InnoDB data and indexes.
# Target: ~60–70% of pod memory limit (set to 512M for a 1GB pod).
# Increase if pod memory limit is higher (e.g. 1G for a 2GB pod).
innodb_buffer_pool_size         = 512M
innodb_buffer_pool_instances    = 2

# File-per-table: easier backup, reclaim space after DROP TABLE
innodb_file_per_table           = ON

# Flush method: O_DIRECT avoids double-buffering with OS page cache
innodb_flush_method             = O_DIRECT

# ACID compliance: 1 = fsync on each COMMIT (safest, ~10% slower than 2)
# Set to 2 in dev/test for performance; keep at 1 in production
innodb_flush_log_at_trx_commit  = 1

# Redo log size: larger = better write performance, slower crash recovery
innodb_log_file_size            = 256M

# Row format: DYNAMIC supports long varchar/blob without row overflow issues
innodb_default_row_format       = DYNAMIC

# Strict mode: enforce correct data types and lengths
innodb_strict_mode              = ON

# Status output interval (seconds)
innodb_status_output            = OFF
innodb_status_output_locks      = OFF

# ---------------------------------------------------------------------------
# SQL mode — strict, consistent with application expectations
# ---------------------------------------------------------------------------
sql_mode = STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION

# ---------------------------------------------------------------------------
# Binary logging — enables point-in-time recovery and replication readiness
# Disable (binlog=OFF) if replication is not required to save I/O
# ---------------------------------------------------------------------------
log_bin                         = /var/lib/mysql/mysql-bin
binlog_format                   = ROW
binlog_row_image                = FULL
expire_logs_days                = 7
max_binlog_size                 = 128M
server_id                       = 1

# ---------------------------------------------------------------------------
# Slow query log — capture queries taking >1s for performance analysis
# ---------------------------------------------------------------------------
slow_query_log                  = ON
slow_query_log_file             = /var/lib/mysql/slow.log
long_query_time                 = 1
log_queries_not_using_indexes   = OFF
min_examined_row_limit          = 100

# ---------------------------------------------------------------------------
# General query log — OFF in production; enable for debugging only
# ---------------------------------------------------------------------------
general_log                     = OFF

# ---------------------------------------------------------------------------
# Timestamp handling — required for CURRENT_TIMESTAMP defaults on DATETIME
# ---------------------------------------------------------------------------
explicit_defaults_for_timestamp = ON

# ---------------------------------------------------------------------------
# Temporary tables — used by complex reporting queries
# ---------------------------------------------------------------------------
tmp_table_size                  = 64M
max_heap_table_size             = 64M

# ---------------------------------------------------------------------------
# Packet size — allow large justification/JSON fields
# ---------------------------------------------------------------------------
max_allowed_packet              = 64M

# ---------------------------------------------------------------------------
# Table cache
# ---------------------------------------------------------------------------
table_open_cache                = 2000
table_definition_cache          = 1000

# ---------------------------------------------------------------------------
# Thread cache — reuse OS threads for reconnecting clients
# ---------------------------------------------------------------------------
thread_cache_size               = 50

[mysql]
default_character_set           = utf8mb4

[client]
default_character_set           = utf8mb4
port                            = 3306
