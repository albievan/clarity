# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
# URL of the frontend app — OAuth callbacks redirect here after login.
# In production set this to https://app.clarity.example.com
FRONTEND_URL=http://localhost:3000

# Additional allowed CORS origins — comma-separated list.
# The API always allows APP_BASE_URL and FRONTEND_URL.
# In development, 'null' is automatically added so the HTML test console works
# when opened directly from the filesystem.
# Examples:
#   CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
#   CORS_ALLOWED_ORIGINS=https://staging.clarity.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────────────
# Pick ONE of the two blocks below. Both drivers are compiled in — DB_DRIVER
# selects which one is used at runtime.

# Option A: Microsoft SQL Server / Azure SQL
DB_DRIVER=sqlserver
DB_DSN=sqlserver://clarity_user:YourPassword@localhost:1433?database=clarity
# Append &TrustServerCertificate=true if using a self-signed cert (dev / docker only)

# Option B: MariaDB / MySQL  (comment out Option A and uncomment these)
# DB_DRIVER=mysql
# DB_DSN=clarity_user:YourPassword@tcp(localhost:3306)/clarity?parseTime=true&loc=UTC&charset=utf8mb4

# ── JWT ────────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with:
#   openssl rand -hex 32
JWT_SECRET=replace-with-256-bit-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ── Redis (session cache, idempotency, rate limits) ────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── Object Storage (S3 / MinIO) ────────────────────────────────────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=clarity-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-west-1
S3_PRESIGN_TTL_MINUTES=15

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Idempotency ────────────────────────────────────────────────────────────────
IDEMPOTENCY_TTL_HOURS=24

# ══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION — LOCAL USERS
# ══════════════════════════════════════════════════════════════════════════════
#
# Local users authenticate with email + password. Passwords are hashed using
# the PasswordHasher interface in internal/domain/auth/service.go.
#
# Development: the default stub uses SHA-256 (fast, insecure — dev only).
# Production:  swap stubHasher for BcryptHasher after `go mod tidy` resolves
#              golang.org/x/crypto/bcrypt (see service.go inline comments).
#
# Security policy (configured per-tenant via the security_policy table, or
# these defaults apply when no row exists):
#
#   Lockout threshold     : 5 failed attempts
#   Lockout duration      : 30 minutes
#   Minimum password len  : 12 characters
#   Password history count: 5 (future — not yet enforced in repo layer)
#   MFA required          : false (override per-tenant in security_policy)
#
# There are no env vars for password policy — it is driven by database rows.
# Use POST /v1/admin/security-policy to update policy for a tenant.

# ══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION — GOOGLE OAUTH 2.0
# ══════════════════════════════════════════════════════════════════════════════
#
# How to obtain these credentials:
#   1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (application type: Web application)
#   3. Add the redirect URI shown below to "Authorised redirect URIs"
#   4. Copy the Client ID and Client Secret here
#
# Redirect URI to register in Google Cloud Console:
#   http://localhost:8080/v1/auth/oauth/google/callback  (development)
#   https://api.clarity.example.com/v1/auth/oauth/google/callback  (production)
#
# Leave blank to disable Google login — the /auth/oauth/google/init endpoint
# will return 400 Bad Request if GOOGLE_CLIENT_ID is empty.
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Override the callback URL only if APP_BASE_URL is not set correctly:
# GOOGLE_REDIRECT_URL=https://api.clarity.example.com/v1/auth/oauth/google/callback

# ══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION — APPLE SIGN IN
# ══════════════════════════════════════════════════════════════════════════════
#
# Apple Sign In requires an Apple Developer account ($99/yr).
#
# How to obtain these credentials:
#   1. https://developer.apple.com/ → Certificates, IDs & Profiles
#   2. Register a Services ID (this becomes your APPLE_CLIENT_ID)
#      e.g.  com.clarity.api
#   3. Enable "Sign In with Apple" and configure the domain + redirect URI:
#      Domain   : api.clarity.example.com (or localhost for dev via ngrok)
#      Return URL: https://api.clarity.example.com/v1/auth/oauth/apple/callback
#   4. Create a Key with "Sign In with Apple" capability — download the .p8 file
#   5. Generate the client_secret JWT from the .p8 key:
#      https://developer.apple.com/documentation/sign_in_with_apple/generate_and_validate_tokens
#
# APPLE_CLIENT_SECRET is a pre-generated ES256-signed JWT (not the raw .p8 key).
# It expires after a maximum of 6 months — rotate it before then.
#
# NOTE: Apple sends callbacks as HTTP POST (form_post response mode), not GET.
#       The callback URL must be HTTPS in production. Use ngrok for local dev:
#         ngrok http 8080
#       Then set APPLE_REDIRECT_URL to your ngrok HTTPS URL.
#
# Leave blank to disable Apple login.
#
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
# APPLE_REDIRECT_URL=https://api.clarity.example.com/v1/auth/oauth/apple/callback

# ══════════════════════════════════════════════════════════════════════════════
# DATABASE SCHEMA — NEW TABLES REQUIRED FOR AUTH & USERS
# ══════════════════════════════════════════════════════════════════════════════
#
# The following tables must exist in your database. SQL is provided for both
# SQL Server and MariaDB dialects.
#
# ── users (updated columns) ──────────────────────────────────────────────────
#   The auth domain reads/writes these columns in addition to whatever
#   columns your existing users table has:
#
#   password_hash        VARCHAR(255) NULL
#   status               VARCHAR(20)  NOT NULL DEFAULT 'active'
#   auth_provider        VARCHAR(20)  NOT NULL DEFAULT 'local'
#   avatar_url           VARCHAR(500) NULL
#   first_name           VARCHAR(100) NULL
#   last_name            VARCHAR(100) NULL
#   display_name         VARCHAR(200) NULL
#   failed_login_count   INT          NOT NULL DEFAULT 0
#   locked_until         DATETIME     NULL
#   mfa_enabled          BIT/TINYINT  NOT NULL DEFAULT 0
#   mfa_secret           VARCHAR(100) NULL
#   mfa_secret_pending   VARCHAR(100) NULL
#   require_pw_change    BIT/TINYINT  NOT NULL DEFAULT 0
#   last_login_at        DATETIME     NULL
#
# ── oauth_identities ─────────────────────────────────────────────────────────
#
#   MariaDB:
#   CREATE TABLE oauth_identities (
#     id           VARCHAR(32)  NOT NULL PRIMARY KEY,
#     user_id      VARCHAR(32)  NOT NULL,
#     tenant_id    VARCHAR(32)  NOT NULL,
#     provider     VARCHAR(20)  NOT NULL,   -- 'google' | 'apple'
#     provider_uid VARCHAR(255) NOT NULL,   -- subject claim from the provider
#     email        VARCHAR(255) NOT NULL,
#     display_name VARCHAR(200) NULL,
#     avatar_url   VARCHAR(500) NULL,
#     created_at   DATETIME     NOT NULL,
#     UNIQUE KEY uq_identity (tenant_id, provider, provider_uid),
#     FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
#   );
#
# ── user_roles ────────────────────────────────────────────────────────────────
#
#   MariaDB:
#   CREATE TABLE user_roles (
#     id          VARCHAR(32)  NOT NULL PRIMARY KEY,
#     user_id     VARCHAR(32)  NOT NULL,
#     tenant_id   VARCHAR(32)  NOT NULL,
#     role_name   VARCHAR(50)  NOT NULL,
#     granted_by  VARCHAR(32)  NOT NULL,
#     granted_at  DATETIME     NOT NULL,
#     UNIQUE KEY uq_user_role (tenant_id, user_id, role_name),
#     FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
#   );
#
# ── sessions ──────────────────────────────────────────────────────────────────
#
#   MariaDB:
#   CREATE TABLE sessions (
#     id           VARCHAR(32)  NOT NULL PRIMARY KEY,
#     user_id      VARCHAR(32)  NOT NULL,
#     tenant_id    VARCHAR(32)  NOT NULL,
#     token_hash   VARCHAR(64)  NOT NULL,   -- SHA-256 hex of raw refresh token
#     ip_address   VARCHAR(45)  NULL,
#     user_agent   VARCHAR(500) NULL,
#     expires_at   DATETIME     NOT NULL,
#     revoked_at   DATETIME     NULL,
#     last_used_at DATETIME     NOT NULL,
#     FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
#   );
#
# ── password_reset_tokens ─────────────────────────────────────────────────────
#
#   MariaDB:
#   CREATE TABLE password_reset_tokens (
#     id         VARCHAR(32) NOT NULL PRIMARY KEY,
#     user_id    VARCHAR(32) NOT NULL,
#     tenant_id  VARCHAR(32) NOT NULL,
#     token_hash VARCHAR(64) NOT NULL UNIQUE,
#     expires_at DATETIME    NOT NULL,
#     used_at    DATETIME    NULL,
#     FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
#   );
#
# ── mfa_backup_codes ──────────────────────────────────────────────────────────
#
#   MariaDB:
#   CREATE TABLE mfa_backup_codes (
#     id        VARCHAR(32) NOT NULL PRIMARY KEY,
#     user_id   VARCHAR(32) NOT NULL,
#     tenant_id VARCHAR(32) NOT NULL,
#     code_hash VARCHAR(64) NOT NULL,  -- SHA-256 hex of plaintext code
#     used_at   DATETIME    NULL,
#     FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
#   );
#
# ── security_policy ───────────────────────────────────────────────────────────
#
#   MariaDB:
#   CREATE TABLE security_policy (
#     tenant_id             VARCHAR(32) NOT NULL PRIMARY KEY,
#     lockout_threshold     INT         NOT NULL DEFAULT 5,
#     lockout_duration_mins INT         NOT NULL DEFAULT 30,
#     mfa_required          TINYINT     NOT NULL DEFAULT 0,
#     min_password_length   INT         NOT NULL DEFAULT 12,
#     password_history_count INT        NOT NULL DEFAULT 5
#   );
