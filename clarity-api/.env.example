APP_ENV=development
APP_PORT=8080
APP_BASE_URL=https://api.clarity.example.com

# ── Database ───────────────────────────────────────────────────────────────────
# Pick ONE of the two blocks below by setting DB_DRIVER and DB_DSN.
# Both drivers are compiled in — only DB_DRIVER selects which one is used.

# Option A: Microsoft SQL Server / Azure SQL
DB_DRIVER=sqlserver
DB_DSN=sqlserver://clarity_user:YourPassword@localhost:1433?database=clarity
# Add &TrustServerCertificate=true if using a self-signed cert (dev/docker only)

# Option B: MariaDB / MySQL  (comment out Option A above and uncomment these)
# DB_DRIVER=mysql
# DB_DSN=clarity_user:YourPassword@tcp(localhost:3306)/clarity?parseTime=true&loc=UTC&charset=utf8mb4

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-256-bit-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ── Redis (session cache, idempotency, rate limits) ────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── Object Storage (S3 / MinIO) ────────────────────────────────────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=clarity-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-west-1
S3_PRESIGN_TTL_MINUTES=15

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Idempotency ────────────────────────────────────────────────────────────────
IDEMPOTENCY_TTL_HOURS=24
