# ── Clarity Frontend — Environment Variables ──────────────────────────────────
#
# Copy this to .env and edit as needed:
#   cp .env.example .env
#
# These variables are read by docker-compose.yml at runtime. They do NOT get
# baked into the Docker image — they affect the host port mapping only.
#
# The HTML file itself reads API_BASE_URL from its built-in default
# (http://localhost:8080/v1) or from whatever is saved in localStorage via
# the Config tab in the UI.

# Host port to expose the frontend on.
# Access the console at http://localhost:<FRONTEND_PORT>
FRONTEND_PORT=3000
